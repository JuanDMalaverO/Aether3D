/* ── Base ─────────────────────────────────────────────────────────── */
QMainWindow, QWidget {
    background: #0f0f11;
    color: #d4d4e0;
    font-family: "Segoe UI", system-ui, sans-serif;
    font-size: 12px;
}

/* ── Menu bar ─────────────────────────────────────────────────────── */
QMenuBar {
    background: #0a0a0c;
    color: #a0a0b8;
    border-bottom: 1px solid #1e1e28;
    padding: 2px 4px;
    spacing: 2px;
}
QMenuBar::item {
    padding: 4px 10px;
    border-radius: 4px;
}
QMenuBar::item:selected, QMenuBar::item:pressed {
    background: #1e1e2e;
    color: #d4d4e0;
}
QMenu {
    background: #13131a;
    color: #d4d4e0;
    border: 1px solid #2a2a3a;
    border-radius: 6px;
    padding: 4px 0;
}
QMenu::item {
    padding: 6px 28px 6px 14px;
}
QMenu::item:selected {
    background: #6c63ff22;
    color: #c4bcff;
}
QMenu::separator {
    height: 1px;
    background: #2a2a3a;
    margin: 4px 8px;
}

/* ── Dock widgets ─────────────────────────────────────────────────── */
QDockWidget {
    color: #d4d4e0;
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
}
QDockWidget::title {
    background: #0f0f14;
    color: #7070a0;
    padding: 6px 10px;
    border-bottom: 1px solid #1e1e2a;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

/* ── Scroll area ──────────────────────────────────────────────────── */
QScrollArea {
    background: #0f0f11;
    border: none;
}
QScrollBar:vertical {
    background: #0f0f11;
    width: 8px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #2a2a40;
    border-radius: 4px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover { background: #3a3a58; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar:horizontal {
    background: #0f0f11;
    height: 8px;
}
QScrollBar::handle:horizontal {
    background: #2a2a40;
    border-radius: 4px;
    min-width: 24px;
}
QScrollBar::handle:horizontal:hover { background: #3a3a58; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

/* ── Text edit (consola) ─────────────────────────────────────────── */
QTextEdit {
    background: #080810;
    border: none;
    color: #9090b0;
    padding: 6px 8px;
    font-family: "Cascadia Code", "JetBrains Mono", "Consolas", monospace;
    font-size: 11px;
    selection-background-color: #6c63ff44;
}

/* ── Status bar ──────────────────────────────────────────────────── */
QStatusBar {
    background: #080810;
    color: #50506a;
    border-top: 1px solid #1a1a26;
    font-size: 11px;
    padding: 0 8px;
}
QStatusBar::item { border: none; }

   </string>
  </property>

